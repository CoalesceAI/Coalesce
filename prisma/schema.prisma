// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / Team ────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

model User {
  id        String     @id @default(uuid())
  authId    String?    @unique
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  teams     TeamUser[]
}

model TeamUser {
  teamId   String
  userId   String
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model Team {
  id               String     @id @default(uuid())
  orgId            String?    @unique
  name             String
  slug             String     @unique
  apiKey           String     @unique
  // Maps this team to a Slack workspace — used to route Slack events to the correct team
  slackWorkspaceId String?    @unique
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  members          TeamUser[]
  tickets          Ticket[]
  events           Event[]
}

// ─── Tickets ────────────────────────────────────────────────────────────────

enum TicketSource {
  SLACK
  EMAIL
  API
  SDK
}

enum TicketStatus {
  OPEN
  TRIAGING
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  DOCS_ISSUE
  API_BUG
  CONFIG_ERROR
  BILLING
  UNKNOWN
}

model Ticket {
  id                String         @id @default(uuid())
  teamId            String
  source            TicketSource   @default(SLACK)
  status            TicketStatus   @default(OPEN)
  priority          TicketPriority @default(MEDIUM)
  category          TicketCategory @default(UNKNOWN)
  title             String
  rawContent        String
  structuredContext Json?
  agentIdentifier   String?
  // Slack-specific: used for threading replies back to the originating message
  slackChannelId    String?
  slackThreadTs     String?
  // Idempotency: prevents duplicate tickets from agent retries
  // Agents should set this to a stable hash of their error context
  idempotencyKey    String?        @unique
  // Callback: if set, platform POSTs resolution payload here when ticket resolves
  webhookUrl        String?
  slaDeadline       DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  team              Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  resolution        Resolution?
  events            Event[]
}

// ─── Events (SDK ingestion) ──────────────────────────────────────────────────

model Event {
  id              String   @id @default(uuid())
  teamId          String
  agentIdentifier String?
  eventType       String
  payload         Json
  processed       Boolean  @default(false)
  ticketId        String?
  createdAt       DateTime @default(now())
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  ticket          Ticket?  @relation(fields: [ticketId], references: [id])
}

// ─── Resolutions ─────────────────────────────────────────────────────────────

enum ResolutionType {
  DOCS_UPDATE
  CONFIG_CHANGE
  API_ACTION
  MANUAL
}

enum ResolutionOutcome {
  SUCCESS
  FAILURE
  PENDING
}

model Resolution {
  id         String            @id @default(uuid())
  ticketId   String            @unique
  type       ResolutionType
  content    Json
  outcome    ResolutionOutcome @default(PENDING)
  executedAt DateTime?
  createdAt  DateTime          @default(now())
  ticket     Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}
