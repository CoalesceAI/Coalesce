// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

model User {
  id             String          @id @default(uuid())
  authId         String?         @unique
  email          String          @unique
  name           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  teams          TeamUser[]
  watchlistItems WatchlistItem[]
  alertRules     AlertRule[]
}

model TeamUser {
  teamId   String
  userId   String
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model Team {
  id           String        @id @default(uuid())
  orgId        String?       @unique
  name         String
  slug         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  apiKey       String        @unique
  members      TeamUser[]
}

enum Platform {
  POLYMARKET
  KALSHI
}

model WatchlistItem {
  id          String   @id @default(uuid())
  userId      String
  marketId    String
  platform    Platform
  title       String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId, platform])
  @@index([userId])
}

enum AlertType {
  PRICE_ABOVE
  PRICE_BELOW
  SPREAD_ABOVE
}

model AlertRule {
  id          String    @id @default(uuid())
  userId      String
  marketId    String
  platform    Platform
  type        AlertType
  threshold   Float
  active      Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}