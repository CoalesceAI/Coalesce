# Hono API — copy to .env in repo root (see README.md)

# Required
DATABASE_URL=
ANTHROPIC_API_KEY=
CLERK_SECRET_KEY=

# Server
PORT=3000

# Comma-separated origins allowed for browser admin UI (Next.js → Hono). Defaults include localhost:3001.
# CORS_ORIGINS=https://your-admin.example.com

# Optional
# SESSION_TTL_MS=
# FIRECRAWL_API_KEY=

# Seed (npm run seed) — link the AgentMail org to your Clerk account for the admin UI
# Option A: Set SEED_CLERK_USER_ID directly (find it in Clerk Dashboard → Users → User ID)
# SEED_CLERK_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx
# Option B: Set email + password — seed will create the Clerk user if not found, then link
# SEED_USER_EMAIL=you@company.com
# SEED_USER_PASSWORD=YourPassword123!

# Railway Buckets (S3) — optional unless using file uploads
# BUCKET=
# ACCESS_KEY_ID=
# SECRET_ACCESS_KEY=
# ENDPOINT=
# REGION=
