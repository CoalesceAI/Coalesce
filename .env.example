# Hono API — copy to .env in repo root (see README.md)

# Required
DATABASE_URL=
ANTHROPIC_API_KEY=
CLERK_SECRET_KEY=

# Server
PORT=3000

# Optional
# SESSION_TTL_MS=
# FIRECRAWL_API_KEY=

# Railway Buckets (S3) — optional unless using file uploads
# BUCKET=
# ACCESS_KEY_ID=
# SECRET_ACCESS_KEY=
# ENDPOINT=
# REGION=
