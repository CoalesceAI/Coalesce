NODE_ENV=development

# Database
# Pooled URL (Supabase port 6543): use for app runtime. Add ?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://user:password@localhost:5432/core"
# Direct URL (Supabase port 5432): use for migrations (db push, migrate). Add ?sslmode=require
# Get from Supabase: Project Settings → Database → Connection string → "Direct connection"
DIRECT_URL="postgresql://user:password@localhost:5432/core"

# Clerk (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# App URL (used for redirects, invite links, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: override Clerk auth paths (defaults: /sign-in, /sign-up)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Optional: Clerk user-created webhook secret (for webhook verification)
USER_CREATED_WEBHOOK_SECRET="whsec_..."

# Predexon API — server-only secret, powers all market data.
# Get your key at https://dashboard.predexon.com
# Do NOT prefix with NEXT_PUBLIC_ — this must never reach the browser.
PREDEXON_API_KEY="pdx_..."

# OpenAI — powers LLM-based cross-platform market matching.
# Uses text-embedding-3-small for semantic similarity + gpt-4o-mini for verification.
# Cost: < $0.001 per scan. Optional — falls back to text heuristics without it.
OPENAI_API_KEY="sk-..."
