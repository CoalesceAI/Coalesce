{
  "name": "apoyo",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed-agentmail.ts",
    "seed-web": "tsx src/db/seed-from-web.ts",
    "generate-url": "tsx src/db/generate-signed-url.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.78.0",
    "@hono/node-server": "latest",
    "@hono/node-ws": "^1.3.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.7",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "latest"
  }
}
